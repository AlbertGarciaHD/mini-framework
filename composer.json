{
    "name": "albertgarciahd/lume-framework",
    "description": "Simple PHP framework inspired by Laravel",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Lume\\": "src/Lume"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lume\\Tests\\" : "tests"
        }
    },
    "scripts": {
        "tests" : "phpunit --color=always --testdox -v tests/"
    },
    "authors": [
        {
            "name": "AlbertGarciaHD",
            "email": "albertgarcia990@gmail.com"
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    }
}
