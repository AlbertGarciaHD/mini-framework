{
    "name": "albertgarciahd/lume-framework",
    "description": "Simple PHP framework inspired by Laravel",
    "type": "library",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Lume\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lume\\Tests\\" : "tests"
        }
    },
    "scripts": {
        "tests" : "phpunit --color=always --testdox tests/",
        "php-cs-fixer" : "php-cs-fixer fix --diff" 
    },
    "authors": [
        {
            "name": "AlbertGarciaHD",
            "email": "albertgarcia990@gmail.com"
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "friendsofphp/php-cs-fixer": "^3.95"
    }
}
